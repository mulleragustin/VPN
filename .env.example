# ============================================
# WireGuard VPN - Configuración
# ============================================
# Copia este archivo como .env y completá los valores

# REQUERIDO: IP pública o dominio de tu VPS
WG_HOST=tu-vps-ip-o-dominio.com

# REQUERIDO: Hash de la contraseña para la UI web
# Generalo con: docker run -it ghcr.io/wg-easy/wg-easy wgpw 'TU_CONTRASEÑA'
# IMPORTANTE: En el hash resultante, reemplazá cada $ por $$
PASSWORD_HASH=

# Puerto UDP para WireGuard (tráfico VPN)
WG_PORT=51820

# Puerto TCP para la interfaz web
UI_PORT=51821

# Servidores DNS que usarán los clientes VPN
WG_DEFAULT_DNS=1.1.1.1, 8.8.8.8

# IPs permitidas (0.0.0.0/0 = todo el tráfico pasa por la VPN)
WG_ALLOWED_IPS=0.0.0.0/0, ::/0

# Keepalive en segundos (útil para mantener conexión en móviles)
WG_PERSISTENT_KEEPALIVE=25

# Estadísticas de tráfico en la UI
UI_TRAFFIC_STATS=true

# Tipo de gráfico (0=deshabilitado, 1=línea, 2=área, 3=barra)
UI_CHART_TYPE=1

# Idioma de la interfaz
LANG=en
